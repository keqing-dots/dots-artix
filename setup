#!/usr/bin/env bash
set -euo pipefail

[[ "$EUID" -ne 0 ]] || { echo "Run as your regular user, not root."; exit 1; }

R="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

die() { echo "error: $*" >&2; exit 1; }

[[ "$(dirname "$R")" == "$HOME" ]] || die "Project must be cloned directly into \$HOME (found: $R)"
step() { echo; echo "==> $*"; }

source "$R/source/gpu.sh"

sudo -v
echo "$USER ALL=(ALL) NOPASSWD: ALL" | sudo tee /etc/sudoers.d/99-keqing-setup >/dev/null
trap 'sudo rm -f /etc/sudoers.d/99-keqing-setup' EXIT

SYSTEM_PKGS=(
    bluez
    bluez-openrc
    bluez-utils
    fcitx5
    fontconfig
    git
    dbus
    dbus-openrc
    elogind
    elogind-openrc
    greetd
    greetd-openrc
    grub
    hyprland
    imagemagick
    kitty
    libnotify
    networkmanager
    networkmanager-openrc
    pciutils
    pipewire
    pipewire-alsa
    pipewire-pulse
    qt6-5compat
    quickshell
    stow
    syncthing
    upower
    wireplumber
    wl-clipboard
    xdg-desktop-portal
    xdg-desktop-portal-hyprland
    xdg-utils
    zsh
)

EXTRA_PKGS=(
    bat
    brightnessctl
    btop
    cava
    cmake
    desktop-file-utils
    fastfetch
    fd
    hyprshot
    jq
    noto-fonts-cjk
    otf-comicshanns-nerd
    starship
    lz4
    xxhash
    yazi
    zoxide
    zsh-autosuggestions
)

AUR_PKGS=(
    bdf2psf
    otf2bdf
    unimatrix-git
    visual-studio-code-bin
    zen-browser-bin
)

# 1. paru
step "Installing paru"
if ! command -v paru &>/dev/null; then
    sudo pacman -S --needed --noconfirm base-devel git
    tmp=$(mktemp -d)
    git clone https://aur.archlinux.org/paru.git "$tmp/paru"
    (cd "$tmp/paru" && makepkg -si --noconfirm)
    rm -rf "$tmp"
else
    echo "paru already installed"
fi

# 2. Dependencies
step "Installing system packages"
paru -S --needed --noconfirm "${SYSTEM_PKGS[@]}"

step "Installing extra packages"
paru -S --needed --noconfirm "${EXTRA_PKGS[@]}"

step "Installing AUR packages"
paru -S --needed --noconfirm "${AUR_PKGS[@]}"

# 3. GPU drivers
step "Installing GPU drivers"
[[ "$(uname -r)" =~ -(arch|artix)[0-9] ]] && dkms_suffix="" || dkms_suffix="-dkms"
_detect_gpu

if $has_nvidia; then
    chip=$(echo "$_gpu_gpus" | grep -i nvidia | grep -oP '\b(TU|GA|AD|GB)\d+' | head -1)
    [[ -n "$chip" ]] \
        && paru -S --needed --noconfirm "nvidia-open${dkms_suffix}" nvidia-utils egl-wayland \
        || paru -S --needed --noconfirm "nvidia${dkms_suffix}" nvidia-utils egl-wayland
fi
$has_amd   && paru -S --needed --noconfirm mesa vulkan-radeon libva-mesa-driver
$has_intel && paru -S --needed --noconfirm mesa vulkan-intel intel-media-driver
! $has_nvidia && ! $has_amd && ! $has_intel && echo "GPU not detected, skipping driver installation"

# 4. Enable services
step "Installing custom init scripts"
sudo install -Dm755 "$R/system/init.d/tailscaled" /etc/init.d/tailscaled

step "Enabling services"
sudo rc-update add dbus default
sudo rc-update add elogind default
sudo rc-update add NetworkManager default
sudo rc-update add bluetoothd default

# 5. GRUB install
mountpoint -q /boot/efi && efi_dir=/boot/efi || efi_dir=/boot
sudo mkdir -p /boot/grub
sudo grub-install --target=x86_64-efi --efi-directory="$efi_dir" --bootloader-id=GRUB
sudo grub-mkconfig -o /boot/grub/grub.cfg

# 6. update (skip: plymouth, sddm, grub)
step "Running update modules"
for mod in stow sudo font cursor desktop bin vscode yazi; do
    echo "  -> update $mod"
    "$R/scripts/update" "$mod"
done

# 7. Clone and setup keqing-shell
step "Cloning keqing-shell"
rm -rf "$HOME/keqing-shell"
git clone https://github.com/keqing-dots/shell.git "$HOME/keqing-shell"

step "Setting up keqing-shell"
"$HOME/keqing-shell/setup"

# 8. Git
step "Configuring git"
git config --global pull.rebase true
git config --global push.autoSetupRemote true

# 10. Autologin
step "Configuring autologin"
sudo "$R/system/autologin"

cd "$HOME"
echo
echo "Setup complete. Reboot now: sudo reboot"
