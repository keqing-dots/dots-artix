#!/usr/bin/env bash
set -euo pipefail

declare -A CHECK=(
    [dk]="docker"
    [pg]="psql"
    [ts]="tailscale"
)
declare -A START=(
    [dk]="docker"
    [pg]="postgresql"
    [ts]="tailscaled"
)
declare -A STOP=(
    [dk]="docker"
    [pg]="postgresql"
    [ts]="tailscaled"
)
declare -A NAME=(
    [dk]="Docker"
    [pg]="PostgreSQL"
    [ts]="Tailscale"
)

usage() { echo "Usage: $(basename "$0") {dk|pg|ts} {start|stop|restart|status}"; exit 1; }
[[ $# -eq 2 ]] || usage

svc="$1"; action="$2"
[[ -v CHECK[$svc] ]] || { echo "Unknown service: $svc"; usage; }

command -v "${CHECK[$svc]}" &>/dev/null || { echo "${NAME[$svc]} is not installed."; exit 1; }

primary="${START[$svc]}"
active() { rc-service "$primary" status &>/dev/null; }

case "$action" in
    start)
        active && { echo "${NAME[$svc]} is already running."; exit 0; }
        echo "Starting ${NAME[$svc]}..."
        sudo rc-service "$primary" start
        echo "${NAME[$svc]} running."
        ;;
    stop)
        active || { echo "${NAME[$svc]} is already stopped."; exit 0; }
        echo "Stopping ${NAME[$svc]}..."
        sudo rc-service "$primary" stop
        echo "${NAME[$svc]} stopped."
        ;;
    restart)
        echo "Restarting ${NAME[$svc]}..."
        sudo rc-service "$primary" restart
        echo "${NAME[$svc]} running."
        ;;
    status)
        active && echo "${NAME[$svc]}: running" || echo "${NAME[$svc]}: stopped"
        ;;
    *)
        usage
        ;;
esac
