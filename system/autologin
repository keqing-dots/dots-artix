#!/usr/bin/env bash
set -euo pipefail

[[ "$EUID" -eq 0 && -n "${SUDO_USER:-}" ]] || { echo "Run with: sudo $0"; exit 1; }

TARGET_USER="$SUDO_USER"
TARGET_HOME=$(getent passwd "$TARGET_USER" | cut -d: -f6)

# zsh
if ! command -v zsh &>/dev/null; then
    pacman -S --noconfirm zsh
fi
ZSH_PATH=$(command -v zsh)
grep -qF "$ZSH_PATH" /etc/shells || echo "$ZSH_PATH" >> /etc/shells
[[ "$(getent passwd "$TARGET_USER" | cut -d: -f7)" == "$ZSH_PATH" ]] || chsh -s "$ZSH_PATH" "$TARGET_USER"

# greetd
if ! command -v greetd &>/dev/null; then
    pacman -S --noconfirm greetd greetd-openrc
fi

# disable other display managers / login services
for dm in sddm lightdm gdm lxdm ly slim; do
    rc-update del "$dm" default 2>/dev/null || true
    rc-service "$dm" stop 2>/dev/null || true
done

# greetd autologin
mkdir -p /etc/greetd
cat <<EOF > /etc/greetd/config.toml
[terminal]
vt = 1

[default_session]
command = "agreety --cmd $ZSH_PATH"
user = "greeter"

[initial_session]
command = "dbus-run-session Hyprland"
user = "$TARGET_USER"
EOF

rc-update add greetd default

echo "Done. Reboot to apply."
